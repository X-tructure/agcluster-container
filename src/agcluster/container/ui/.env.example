# AgCluster API URL (client-side: used by browser JavaScript)
NEXT_PUBLIC_API_URL=http://localhost:8000

# AgCluster API URL (server-side: used by Next.js API routes, e.g. /api/ai/chat)
# In Docker Compose this is set to http://api:8000 (internal service name)
# For local development outside Docker, keep this as http://localhost:8000
AGCLUSTER_API_URL=http://localhost:8000
